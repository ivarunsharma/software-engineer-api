# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.

# PostgreSQL credentials used by docker-compose
POSTGRES_USER=vsv
POSTGRES_PASSWORD=changeme_use_a_strong_password

# Port Docker maps Postgres to on the host
DB_PORT=5332

# Spring Boot datasource (should match docker-compose values)
DB_URL=jdbc:postgresql://localhost:5332/vsv
DB_USERNAME=vsv
DB_PASSWORD=changeme_use_a_strong_password

# Hibernate DDL strategy: update (keep data), create-drop (wipe on restart)
JPA_DDL_AUTO=update

# Set to true only during local debugging — logs all SQL queries
SHOW_SQL=false
